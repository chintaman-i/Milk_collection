<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Loan Repayment"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/remainingAmountTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remaining: ₹0"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/paymentAmountEt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Repayment Amount"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/remarkEt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Remark (Optional)"
        android:layout_marginTop="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <Button
            android:id="@+id/cancelBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel" />

        <Button
            android:id="@+id/saveBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save Payment" />

    </LinearLayout>

</LinearLayout>