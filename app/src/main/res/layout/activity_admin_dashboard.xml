<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="#2E7D32">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Milk Collection System"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Admin Dashboard"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- OPERATIONS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Operations"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/feedOrdersBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📦 Feed Orders"
                android:textAllCaps="false"
                android:textColor="#000"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Milk Entry -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/milkEntryBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🥛 Milk Collection Entry"
                android:textAllCaps="false"
                android:textColor="#000"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Payment Entry -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/paymentEntryBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💰 Payment Entry"
                android:textAllCaps="false"
                android:textColor="#000"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Manage Feed -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/manageFeedBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌾 Manage Feed Stock"
                android:textAllCaps="false"
                android:textColor="#000"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- MANAGEMENT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Management"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="12dp"/>

        <!-- Manage Users -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/manageUsersBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👥 Manage Users"
                android:textAllCaps="false"
                android:textColor="#000"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Farmer Management -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/farmerManagementBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚜 Farmer Management"
                android:textAllCaps="false"
                android:textColor="#000"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- REPORTS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reports and History"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="12dp"/>

        <!-- Global Milk History -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/globalMilkHistoryBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📜 Global Milk History"
                android:textAllCaps="false"
                android:textColor="#000"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Global Payment History -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/globalPaymentHistoryBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💳 Global Payment History"
                android:textAllCaps="false"
                android:textColor="#000"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Loan Requests -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/loanRequestsBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏦 Loan Requests"
                android:textAllCaps="false"
                android:textColor="#000"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Logout -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/logoutBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚪 Logout"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:textStyle="bold"
                android:background="#F44336"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>