<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        
        android:padding="16dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Milk Collection Entry"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:layout_marginBottom="20dp"/>

        <!-- FARMER ID -->
        <EditText
            android:id="@+id/farmerIdEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Farmer ID"
            android:layout_marginBottom="12dp"/>

        <!-- QUANTITY -->
        <EditText
            android:id="@+id/quantityEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Milk Quantity (Litres)"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <!-- FAT -->
        <EditText
            android:id="@+id/fatEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fat %"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <!-- SNF -->
        <EditText
            android:id="@+id/snfEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="SNF %"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <!-- SESSION -->
        <Spinner
            android:id="@+id/sessionSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <!-- ANIMAL -->
        <Spinner
            android:id="@+id/animalSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <!-- TOTAL -->
        <TextView
            android:id="@+id/totalText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Amount: ₹0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="20dp"/>

        <!-- SAVE BUTTON -->
        <Button
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Entry"/>

    </LinearLayout>

</ScrollView>